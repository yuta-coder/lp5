#include <iostream>
#include <vector>
#include <stack>
#include <omp.h>

using namespace std;

const int MAX = 100000;

vector<int> graph[MAX];
bool visited[MAX];

void dfs(int node)
{
    stack<int> s;
    s.push(node);

    while (!s.empty())
    {
        int curr_node;

        #pragma omp critical
        {
            if (!s.empty())
            {
                curr_node = s.top();
                s.pop();
            }
            else
            {
                curr_node = -1;
            }
        }

        if (curr_node == -1)
            continue;

        bool alreadyVisited = false;

        #pragma omp critical
        {
            if (!visited[curr_node])
            {
                visited[curr_node] = true;
            }
            else
            {
                alreadyVisited = true;
            }
        }

        if (!alreadyVisited)
        {
            #pragma omp parallel for
            for (int i = 0; i < graph[curr_node].size(); i++)
            {
                int adj_node = graph[curr_node][i];

                #pragma omp critical
                {
                    if (!visited[adj_node])
                    {
                        s.push(adj_node);
                    }
                }
            }
        }
    }
}

int main()
{
    int n, m, start_node;

    cout << "Enter number of nodes: ";
    cin >> n;

    cout << "Enter number of edges: ";
    cin >> m;

    cout << "Enter starting node for DFS: ";
    cin >> start_node;

    cout << "Enter edges (u v):\n";

    for (int i = 0; i < m; i++)
    {
        int u, v;
        cin >> u >> v;

        graph[u].push_back(v);
        graph[v].push_back(u);
    }

    #pragma omp parallel for
    for (int i = 0; i < n; i++)
    {
        visited[i] = false;
    }

    dfs(start_node);

    cout << "\nVisited nodes: ";

    for (int i = 0; i < n; i++)
    {
        if (visited[i])
            cout << i << " ";
    }

    return 0;
}
